# OmniBridge — environment variables (development convenience only)
#
# Copy this file to .env for local development. The .env file is gitignored
# and MUST NOT be committed or shipped in a release build.
#
# The `VITE_ANTHROPIC_API_KEY` below is only honored when running
# `npm run tauri dev` (import.meta.env.DEV). Production builds ignore it,
# so release binaries never leak your key. End users paste their own key
# into the Settings modal at first launch.

VITE_ANTHROPIC_API_KEY=
